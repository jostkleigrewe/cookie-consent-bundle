{
    "name": "jostkleigrewe/cookie-consent-bundle",
    "description": "Symfony 8 bundle for GDPR-compliant cookie consent with Twig, Stimulus, and Turbo integration.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "symfony8", "symfony-ux", "bundle", "gdpr", "dsgvo", "cookie", "cookie-consent", "cookie-banner", "consent", "consent-management", "cmp", "privacy", "stimulus", "turbo"],
    "homepage": "https://github.com/jostkleigrewe/cookie-consent-bundle",
    "authors": [
        {
            "name": "Sven Jostkleigrewe"
        }
    ],
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/asset-mapper": "^8.0",
        "symfony/stimulus-bundle": "^2.0",
        "symfony/config": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/ux-twig-component": "^2.0",
        "symfony/security-csrf": "^8.0",
        "symfony/security-http": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "doctrine/dbal": "^4.0",
        "doctrine/orm": "^3.6",
        "phpstan/phpstan": "^1.11",
        "symfony/browser-kit": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/phpunit-bridge": "^7.1"
    },
    "suggest": {
        "doctrine/doctrine-bundle": "Optional: enables Doctrine integration and storage backends",
        "doctrine/orm": "Optional: enables ORM-backed consent storage and audit logging",
        "doctrine/dbal": "For database-backed consent storage (DBAL adapter)",
        "symfony/security-bundle": "Optional: enables user-based audit logging via the security token storage"
    },
    "autoload": {
        "psr-4": {
            "Jostkleigrewe\\CookieConsentBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jostkleigrewe\\CookieConsentBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/simple-phpunit",
        "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon",
        "ci": [
            "composer validate --strict",
            "@test",
            "@phpstan"
        ]
    },
    "support": {
        "issues": "https://github.com/jostkleigrewe/cookie-consent-bundle/issues",
        "source": "https://github.com/jostkleigrewe/cookie-consent-bundle"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1-dev"
        }
    }
}
