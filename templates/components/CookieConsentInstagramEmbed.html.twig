{# DE: Instagram-Embed mit Consent-Placeholder. #}
{# EN: Instagram embed with consent placeholder. #}
{% set category = category|default('marketing') %}
{% set vendor = vendor|default(null) %}
{% set title = title|default('Instagram post') %}
{% set post_url = post_url|default('') %}
{% set categories = cookie_consent_categories() %}
{% set category_config = categories[category] ?? {} %}
{% set category_label = category_config.label ?? category|title %}
{% set vendor_label = vendor ? ((category_config.vendors[vendor].label ?? vendor|title)) : null %}
{% set placeholder_default = vendor
    ? 'cookie_consent.embed_vendor_placeholder'|trans({'%category%': category_label, '%vendor%': vendor_label})
    : 'cookie_consent.embed_placeholder'|trans({'%category%': category_label})
%}

{{ include('@CookieConsent/components/CookieConsentEmbed.html.twig', {
    type: 'html',
    html: '<blockquote class="instagram-media" data-instgrm-permalink="' ~ post_url ~ '" data-instgrm-version="14"></blockquote>',
    title: title,
    category: category,
    vendor: vendor,
    script_src: 'https://www.instagram.com/embed.js',
    callback: 'instgrm.Embeds.process',
    placeholder: placeholder|default(placeholder_default)
}) }}
