{# DE: YouTube-Embed mit Consent-Placeholder (auf Embed-Helper). #}
{# EN: YouTube embed with consent placeholder (via embed helper). #}
{% set category = category|default('marketing') %}
{% set vendor = vendor|default(null) %}
{% set title = title|default('YouTube video') %}
{% set categories = cookie_consent_categories() %}
{% set category_config = categories[category] ?? {} %}
{% set category_label = category_config.label ?? category|title %}
{% set vendor_label = vendor ? ((category_config.vendors[vendor].label ?? vendor|title)) : null %}
{% set placeholder_default = vendor
    ? 'cookie_consent.youtube_vendor_placeholder'|trans({'%category%': category_label, '%vendor%': vendor_label})
    : 'cookie_consent.youtube_placeholder'|trans({'%category%': category_label})
%}

{{ include('@CookieConsent/components/CookieConsentEmbed.html.twig', {
    src: 'https://www.youtube-nocookie.com/embed/' ~ video_id,
    title: title,
    category: category,
    vendor: vendor,
    type: 'iframe',
    allow: 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture',
    aspect_ratio: '16 / 9',
    placeholder: placeholder|default(placeholder_default)
}) }}
