{% extends layout_template %}

{% block stylesheets %}
    {{ parent() }}
    {# DE: Bundle-CSS über AssetMapper laden. EN: Load bundle CSS via AssetMapper. #}
    <link rel="stylesheet" href="{{ asset('@jostkleigrewe/cookie-consent-bundle/styles/cookie_consent.css') }}">
    <style>
        .cookie-consent-showcase {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f1f5f9;
            padding: 2rem;
        }

        .showcase-header {
            max-width: 1400px;
            margin: 0 auto 2rem;
            text-align: center;
        }

        .showcase-header h1 {
            margin: 0 0 0.5rem;
            font-size: 2rem;
            color: #0f172a;
        }

        .showcase-header p {
            margin: 0;
            color: #64748b;
        }

        /* Grid: max 2 Spalten für mehr Platz */
        .showcase-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
            max-width: 1800px;
            margin: 0 auto;
        }

        @media (max-width: 1200px) {
            .showcase-grid {
                grid-template-columns: 1fr;
            }
        }

        .showcase-card {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .showcase-card-header {
            padding: 1rem 1.25rem;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .showcase-card-header h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
        }

        .showcase-card-tags {
            display: flex;
            gap: 0.5rem;
        }

        .showcase-tag {
            padding: 0.25rem 0.6rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .showcase-tag-variant { background: #dbeafe; color: #1e40af; }
        .showcase-tag-theme-day { background: #fef3c7; color: #92400e; }
        .showcase-tag-theme-night { background: #1e293b; color: #e2e8f0; }
        .showcase-tag-density-normal { background: #dcfce7; color: #166534; }
        .showcase-tag-density-compact { background: #fce7f3; color: #9d174d; }

        .showcase-card-body {
            padding: 2rem;
            display: flex;
            align-items: flex-start;
            justify-content: center;
        }

        .cookie-consent-showcase .showcase-card.theme-night {
            background: #0f172a;
        }

        .cookie-consent-showcase .showcase-card.theme-night .showcase-card-header {
            background: #111827;
            border-bottom-color: #1f2937;
        }

        .cookie-consent-showcase .showcase-card.theme-night .showcase-card-header h3 {
            color: #e2e8f0;
        }

        .cookie-consent-showcase .showcase-card-body.theme-night {
            background: #0f172a;
        }

        /* Preview container - keeps modals visible inside cards */
        .preview-container {
            width: 100%;
            max-width: 100%;
        }

        .preview-container .cookie-consent-modal {
            display: flex !important;
            position: relative !important;
            inset: auto !important;
            padding: 0 !important;
            background: transparent !important;
            z-index: auto !important;
        }

        .preview-container .cookie-consent-dialog {
            width: 100% !important;
        }

        .preview-container .modal-content {
            max-height: none !important;
        }

        .showcase-actions {
            max-width: 1400px;
            margin: 2rem auto;
            text-align: center;
        }

        .showcase-btn {
            display: inline-block;
            padding: 0.75rem 1.5rem;
            background: #2563eb;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            margin: 0 0.5rem;
        }

        .showcase-btn:hover {
            background: #1d4ed8;
            color: #ffffff;
        }

        .showcase-info {
            max-width: 1400px;
            margin: 0 auto 2rem;
            padding: 1rem 1.5rem;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            color: #1e40af;
            font-size: 0.9rem;
        }

        .showcase-info code {
            background: #dbeafe;
            padding: 0.15rem 0.4rem;
            border-radius: 4px;
            font-size: 0.85rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="cookie-consent-showcase">
        <div class="showcase-header">
        <h1>Cookie Consent Template Showcase</h1>
        <p>Visual preview of all variant, theme, and density combinations ({{ combinations|length }} total)</p>
        </div>

        <div class="showcase-info">
        <strong>CSS einbinden:</strong> In deiner App nur <code>bundles/cookieconsent/styles/cookie_consent.css</code> einbinden.
        Diese Datei importiert automatisch alle benötigten Styles (base, themes, variants).
        </div>

        <div class="showcase-grid">
        {% for combo in combinations %}
            <div class="showcase-card {% if combo.theme == 'night' %}theme-night{% endif %}">
                <div class="showcase-card-header">
                    <h3>{{ combo.variant|capitalize }} / {{ combo.theme|capitalize }} / {{ combo.density|capitalize }}</h3>
                    <div class="showcase-card-tags">
                        <span class="showcase-tag showcase-tag-variant">{{ combo.variant }}</span>
                        <span class="showcase-tag showcase-tag-theme-{{ combo.theme }}">{{ combo.theme }}</span>
                        <span class="showcase-tag showcase-tag-density-{{ combo.density }}">{{ combo.density }}</span>
                    </div>
                </div>
                <div class="showcase-card-body {% if combo.theme == 'night' %}theme-night{% endif %}">
                    <div class="preview-container">
                        {% include '@CookieConsent/modal.html.twig' with template_data|merge({
                            variant: combo.variant,
                            theme: combo.theme,
                            density: combo.density,
                            id_suffix: [combo.variant, combo.theme, combo.density]|join('-')
                        }) %}
                    </div>
                </div>
            </div>
        {% endfor %}
        </div>

        <div class="showcase-actions">
        <a href="#" class="showcase-btn" onclick="location.reload(); return false;">Refresh Preview</a>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // DE: Mini-Interaktion für die Showcase-Seite (ohne Stimulus).
        // EN: Minimal interaction for the showcase page (without Stimulus).
        document.addEventListener('DOMContentLoaded', () => {
            const escapeSelector = (value) => {
                if (window.CSS && typeof window.CSS.escape === 'function') {
                    return window.CSS.escape(value);
                }
                return String(value).replace(/["\\]/g, '\\$&');
            };

            const updateCategory = (category, enabled) => {
                const safeCategory = escapeSelector(category);

                document
                    .querySelectorAll(`[data-consent-vendor-list="true"][data-consent-category-name="${safeCategory}"]`)
                    .forEach((list) => {
                        if (enabled) {
                            list.removeAttribute('hidden');
                        } else {
                            list.setAttribute('hidden', 'hidden');
                        }
                    });

                document
                    .querySelectorAll(`input[data-consent-type="vendor"][data-consent-category-name="${safeCategory}"]`)
                    .forEach((checkbox) => {
                        const required = checkbox.dataset.consentRequired === 'true';

                        if (required) {
                            checkbox.disabled = true;
                            checkbox.checked = true;
                            return;
                        }

                        checkbox.disabled = !enabled;
                        checkbox.checked = enabled && checkbox.dataset.consentDefault === 'true';
                    });
            };

            document
                .querySelectorAll('input[data-consent-type="category"][data-consent-category-name]')
                .forEach((checkbox) => {
                    updateCategory(checkbox.dataset.consentCategoryName, checkbox.checked);
                    checkbox.addEventListener('change', () => {
                        updateCategory(checkbox.dataset.consentCategoryName, checkbox.checked);
                    });
                });
        });
    </script>
{% endblock %}
